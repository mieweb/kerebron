{
  "name": "simple-todos-vue",
  "private": true,
  "scripts": {
    "start": "meteor run",
    "build": "meteor build ../output/vue --directory",
    "test": "meteor test --once --driver-package meteortesting:mocha",
    "test-app": "TEST_WATCH=1 meteor test --full-app --driver-package meteortesting:mocha",
    "visualize": "meteor --production --extra-packages bundle-visualizer"
  },
  "dependencies": {
    "@babel/runtime": "^7.23.5",
    "@kerebron/editor": "latest",
    "@kerebron/extension-basic-editor": "latest",
    "@kerebron/extension-markdown": "latest",
    "@kerebron/extension-odt": "latest",
    "@kerebron/odt-wasm": "latest",
    "@kerebron/extension-tables": "latest",
    "@kerebron/extension-menu": "latest",
    "@kerebron/extension-yjs": "latest",
    "meteor-node-stubs": "1.2.27",
    "vue": "^3.3.9",
    "vue-meteor-tracker": "^3.0.0-beta.7",
    "vue-router": "^4.2.5"
  },
  "meteor": {
    "mainModule": {
      "client": "client/main.js",
      "server": "server/main.js"
    },
    "testModule": "tests/main.js"
  },
  "devDependencies": {
    "@types/meteor": "^2.9.7",
    "@vitejs/plugin-vue": "^3.2.0",
    "autoprefixer": "^10.4.16",
    "meteor-vite": "^1.7.1",
    "postcss": "8.5.15",
    "tailwindcss": "^3.3.5",
    "vite": "^3.2.7"
  }
}
