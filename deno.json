{
  "license": "MIT",
  "workspace": [
    "packages/editor",
    "packages/editor-browserless",
    "packages/editor-react",
    "packages/editor-kits",
    "packages/extension-basic-editor",
    "packages/extension-tables",
    "packages/extension-menu",
    "packages/extension-menu-legacy",
    "packages/extension-markdown",
    "packages/extension-odt",
    "packages/extension-yjs",
    "packages/extension-lsp",
    "packages/extension-codemirror",
    "packages/extension-codejar",
    "packages/extension-autocomplete",
    "packages/extension-dev-toolkit",
    "packages/extension-server-hono",
    "packages/odt-wasm",
    "packages/wasm",
    "packages/test-utils",
    "packages/tree-sitter",
    "packages/legacy-compat",
    "packages/custom-elements",

    "examples/browser-autocomplete",
    "examples/browser-vanilla-code-editor",
    "examples/browser-react",
    "examples/browser-vue",
    "examples/browser-vue-custom-element",
    "examples/browser-vue-lsp",
    "examples/browser-vue-link",
    "examples/browser-vue-comments",
    "examples/browser-custom-element",
    "examples/browser-link-mermaid",
    "examples/browser-two-sides",
    "examples/cli-html-generator",
    "examples/server-hono",
    "examples/mcptest"
  ],
  "compilerOptions": {
    "lib": [
      "dom",
      "deno.window",
      "dom.iterable",
      "dom.asynciterable",
      "deno.ns"
    ]
  },
  "tasks": {
    "build:all": "deno task build:ext-odt && deno task -f @kerebron build",
    "dev": "deno task -f server-hono start",
    "build:legacy-compat": "deno task -f legacy-compat build",
    "build:ext-odt": "deno task -f @kerebron/odt-wasm build",
    "build:ext-wasm": "deno task -f @kerebron/wasm build",
    "test:pre-push": "deno test --no-check --allow-env --allow-net=localhost --allow-read=. --allow-write=. packages/extension-markdown/test/ packages/extension-odt/test/ packages/extension-yjs/test/",
    "postinstall": "ln -sf ../../utils/hooks/commit-msg .git/hooks/commit-msg && ln -sf ../../utils/hooks/pre-commit .git/hooks/pre-commit && ln -sf ../../utils/hooks/pre-push .git/hooks/pre-push",
    "clean": "rm -rf examples/*/.vite examples/*/dist packages/*/.vite packages/*/dist"
  },
  "imports": {
    "@deno/dnt": "jsr:@deno/dnt@0.42.3",
    "@std/assert": "jsr:@std/assert@1",
    "@std/fs": "jsr:@std/fs@1.0.19",
    "@std/path": "jsr:@std/path@1.1.2",
    "asserts": "https://deno.land/std@0.178.0/testing/asserts.ts",

    "prosemirror-state": "npm:prosemirror-state@1.4.3",
    "prosemirror-view": "npm:prosemirror-view@1.40.0",
    "prosemirror-model": "npm:prosemirror-model@1.25.3",
    "prosemirror-transform": "npm:prosemirror-transform@1.10.4",
    "prosemirror-history": "npm:prosemirror-history@1.4.1",
    "prosemirror-dev-toolkit": "npm:prosemirror-dev-toolkit@1.1.8",

    "mathml-to-latex": "npm:mathml-to-latex@1.5.0",
    "mathml2latex": "npm:mathml2latex@1.1.3",

    "yjs": "npm:yjs@13.6.30",
    "y-protocols": "npm:y-protocols@1.0.6",
    "lib0": "npm:lib0@0.2.109",
    "orderedmap": "npm:orderedmap@latest",

    "@xmldom/xmldom": "npm:@xmldom/xmldom@0.7.7",
    "linkedom": "npm:linkedom@0.18.12",

    "vscode-languageserver-protocol": "npm:vscode-languageserver-protocol@3.17.5",
    "vscode-languageserver-textdocument": "npm:vscode-languageserver-textdocument@1.0.12",

    "vite": "npm:vite@7.3.1",
    "vite-plugin-wasm": "npm:vite-plugin-wasm@3.5.0",

    "web-tree-sitter": "npm:web-tree-sitter@0.26.6",

    "thememirror": "npm:thememirror@2.0.1"
  },
  "lint": {
    "exclude": [
      "**/extension-markdown",
      "**/extension-odt",
      "**/extension-lsp",
      "**/extension-codemirror",
      "**/extension-codejar",
      "**/extension-basic-editor",
      "**/editor-kits",
      "**/server-hono/src/lsp",
      "**/browser-react",
      "**/browser-vanilla-code-editor",
      "KEEP REMOVING THOSE!"
    ],
    "rules": {
      "tags": ["recommended"],
      "exclude": [
        "no-explicit-any",
        "prefer-const",
        "no-unused-vars",
        "no-empty-interface"
      ]
    }
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 80,
    "singleQuote": true,
    "semiColons": true,
    "exclude": [
      ".github/**/*.md",
      "**/*.md",
      "**/*.odt.xml",
      "**/*.xml",
      "**/dist"
    ]
  },
  "unstable": ["raw-imports"],
  "nodeModulesDir": "auto"
}
